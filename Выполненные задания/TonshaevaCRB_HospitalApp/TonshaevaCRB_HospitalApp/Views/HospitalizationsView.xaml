<Window x:Class="TonshaevaCRB_HospitalApp.Views.HospitalizationsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление госпитализациями" Height="500" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Name="btnRefresh" Content="Обновить список" Width="150" Height="35" Margin="5" 
                    Background="#3498DB" Foreground="White" Click="btnRefresh_Click"/>
            <Button Name="btnAdd" Content="Добавить госпитализацию" Width="180" Height="35" Margin="5" 
                    Background="#27AE60" Foreground="White" Click="btnAdd_Click"/>
            <Button Name="btnEdit" Content="Редактировать" Width="150" Height="35" Margin="5" 
                    Background="#F39C12" Foreground="White" Click="btnEdit_Click"/>
            <Button Name="btnDischarge" Content="Выписать пациента" Width="160" Height="35" Margin="5" 
                    Background="#E74C3C" Foreground="White" Click="btnDischarge_Click"/>
        </StackPanel>

        <!-- Таблица с данными -->
        <DataGrid Name="dgHospitalizations" Grid.Row="1" AutoGenerateColumns="True" SelectionChanged="dgHospitalizations_SelectionChanged"
                  IsReadOnly="True" Margin="0,10" FontSize="13"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
            <TextBlock Name="txtRoleInfo" VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>