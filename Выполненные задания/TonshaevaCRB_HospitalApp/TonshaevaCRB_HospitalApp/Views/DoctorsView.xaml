<Window x:Class="TonshaevaCRB_HospitalApp.Views.DoctorsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление врачами" Height="550" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма добавления/редактирования -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Фамилия:" Grid.Row="0" Grid.Column="0" Margin="5" FontWeight="Bold"/>
                <TextBox Name="txtLastName" Grid.Row="0" Grid.Column="1" Margin="5" Width="150"/>

                <Label Content="Имя:" Grid.Row="0" Grid.Column="2" Margin="5" FontWeight="Bold"/>
                <TextBox Name="txtFirstName" Grid.Row="0" Grid.Column="3" Margin="5" Width="150"/>

                <Label Content="Отчество:" Grid.Row="1" Grid.Column="0" Margin="5"/>
                <TextBox Name="txtMiddleName" Grid.Row="1" Grid.Column="1" Margin="5" Width="150"/>

                <Label Content="Специализация:" Grid.Row="1" Grid.Column="2" Margin="5" FontWeight="Bold"/>
                <TextBox Name="txtSpecialization" Grid.Row="1" Grid.Column="3" Margin="5" Width="150"/>

                <Label Content="Категория:" Grid.Row="2" Grid.Column="0" Margin="5"/>
                <ComboBox Name="cmbCategory" Grid.Row="2" Grid.Column="1" Margin="5" Width="120">
                    <ComboBoxItem Content="вторая"/>
                    <ComboBoxItem Content="первая"/>
                    <ComboBoxItem Content="высшая"/>
                </ComboBox>

                <Label Content="Номер кабинета:" Grid.Row="2" Grid.Column="2" Margin="5"/>
                <TextBox Name="txtOfficeNumber" Grid.Row="2" Grid.Column="3" Margin="5" Width="150"/>

                <Label Content="Внутренний телефон:" Grid.Row="3" Grid.Column="0" Margin="5"/>
                <TextBox Name="txtPhoneInternal" Grid.Row="3" Grid.Column="1" Margin="5" Width="150"/>

                <Label Content="Дата приёма:" Grid.Row="3" Grid.Column="2" Margin="5" FontWeight="Bold"/>
                <DatePicker Name="dpHireDate" Grid.Row="3" Grid.Column="3" Margin="5" Width="150"/>

                <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Margin="5" HorizontalAlignment="Right">
                    <Button Name="btnAdd" Content="Добавить" Width="100" Margin="5" Background="#27AE60" Foreground="White" Click="btnAdd_Click"/>
                    <Button Name="btnUpdate" Content="Обновить" Width="100" Margin="5" Background="#F39C12" Foreground="White" Click="btnUpdate_Click"/>
                    <Button Name="btnClear" Content="Очистить" Width="100" Margin="5" Background="#95A5A6" Click="btnClear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица с данными -->
        <DataGrid Name="dgDoctors" Grid.Row="1" AutoGenerateColumns="True" SelectionChanged="dgDoctors_SelectionChanged"
                  IsReadOnly="True" Margin="0,10" FontSize="13"/>

        <!-- Кнопка удаления и информация о роли -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
            <Button Name="btnDelete" Content="Уволить выбранного врача" Width="200" Height="35" 
                    Background="#E74C3C" Foreground="White" Click="btnDelete_Click" HorizontalAlignment="Left"/>
            <TextBlock Name="txtRoleInfo" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="Gray" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>