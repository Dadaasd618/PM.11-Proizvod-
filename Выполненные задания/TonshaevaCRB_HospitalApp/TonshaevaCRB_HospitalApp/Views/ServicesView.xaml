<Window x:Class="TonshaevaCRB_HospitalApp.Views.ServicesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление услугами" Height="500" Width="850">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма добавления/редактирования -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Код услуги:" Grid.Row="0" Grid.Column="0" Margin="5" FontWeight="Bold"/>
                <TextBox Name="txtCode" Grid.Row="0" Grid.Column="1" Margin="5" Width="120"/>

                <Label Content="Название услуги:" Grid.Row="0" Grid.Column="2" Margin="5" FontWeight="Bold"/>
                <TextBox Name="txtName" Grid.Row="0" Grid.Column="3" Margin="5" Width="200"/>

                <Label Content="Категория:" Grid.Row="1" Grid.Column="0" Margin="5" FontWeight="Bold"/>
                <ComboBox Name="cmbCategory" Grid.Row="1" Grid.Column="1" Margin="5" Width="120">
                    <ComboBoxItem Content="лабораторная"/>
                    <ComboBoxItem Content="врачебная"/>
                    <ComboBoxItem Content="инструментальная"/>
                    <ComboBoxItem Content="процедурная"/>
                </ComboBox>

                <Label Content="Стоимость (руб):" Grid.Row="1" Grid.Column="2" Margin="5"/>
                <TextBox Name="txtPrice" Grid.Row="1" Grid.Column="3" Margin="5" Width="150"/>

                <Label Content="По ОМС:" Grid.Row="2" Grid.Column="0" Margin="5"/>
                <CheckBox Name="chkIsCompulsory" Grid.Row="2" Grid.Column="1" Margin="5" IsChecked="True" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="5" HorizontalAlignment="Right">
                    <Button Name="btnAdd" Content="Добавить" Width="100" Margin="5" Background="#27AE60" Foreground="White" Click="btnAdd_Click"/>
                    <Button Name="btnUpdate" Content="Обновить" Width="100" Margin="5" Background="#F39C12" Foreground="White" Click="btnUpdate_Click"/>
                    <Button Name="btnClear" Content="Очистить" Width="100" Margin="5" Background="#95A5A6" Click="btnClear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица с данными -->
        <DataGrid Name="dgServices" Grid.Row="1" AutoGenerateColumns="True" SelectionChanged="dgServices_SelectionChanged"
                  IsReadOnly="True" Margin="0,10" FontSize="13"/>

        <!-- Кнопка удаления и информация о роли -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
            <Button Name="btnDelete" Content="Удалить выбранную услугу" Width="200" Height="35" 
                    Background="#E74C3C" Foreground="White" Click="btnDelete_Click" HorizontalAlignment="Left"/>
            <TextBlock Name="txtRoleInfo" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="Gray" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>