<Window x:Class="TonshaevaCRB_HospitalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тоншаевская ЦРБ - Учёт госпитализаций" Height="500" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <TextBlock Text="ГБУЗ НО «Тоншаевская ЦРБ» - Учёт госпитализаций и медицинских услуг" 
                       FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Кнопки навигации -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="20">
            <Button Name="btnPatients" Content="Пациенты (CRUD)" Height="40" Margin="0,5" 
                    Background="#3498DB" Foreground="White" FontSize="14" Click="btnPatients_Click"/>
            <Button Name="btnDoctors" Content="Врачи (CRUD)" Height="40" Margin="0,5" 
                    Background="#3498DB" Foreground="White" FontSize="14" Click="btnDoctors_Click"/>
            <Button Name="btnHospitalizations" Content="Госпитализации (CRUD)" Height="40" Margin="0,5" 
                    Background="#3498DB" Foreground="White" FontSize="14" Click="btnHospitalizations_Click"/>
            <Button Name="btnServices" Content="Услуги (CRUD)" Height="40" Margin="0,5" 
                    Background="#3498DB" Foreground="White" FontSize="14" Click="btnServices_Click"/>

            <Border Background="#E74C3C" CornerRadius="5" Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>