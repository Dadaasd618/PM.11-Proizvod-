<Window x:Class="TonshaevaCRB_HospitalApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Тоншаевская ЦРБ" Height="493" Width="484"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#2C3E50" Offset="0"/>
                <GradientStop Color="#3498DB" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" Width="300">
            <!-- Заголовок -->
            <TextBlock Text="Тоншаевская ЦРБ" FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Учёт госпитализаций и медицинских услуг" FontSize="14" 
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- Поле Логин -->
            <TextBlock Text="Логин" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
            <TextBox Name="txtLogin" FontSize="14" Padding="10" Margin="0,0,0,15"/>

            <!-- Поле Пароль -->
            <TextBlock Text="Пароль" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
            <PasswordBox Name="txtPassword" FontSize="14" Padding="10" Margin="0,0,0,20"/>

            <!-- Кнопка входа -->
            <Button Name="btnLogin" Content="Войти в систему" Height="40" FontSize="14" 
                    Background="#27AE60" Foreground="White" Click="btnLogin_Click" Margin="0,0,0,10"/>

            <!-- Статус -->
            <TextBlock Name="txtStatus" Foreground="#FFD966" FontSize="12" 
                       HorizontalAlignment="Center" TextWrapping="Wrap"/>

            <!-- Информация о ролях -->
            <Border Background="White" CornerRadius="5" Margin="0,20,0,0" Padding="10">
                <TextBlock Text="Тестовые учётные записи:&#x0a;&#x0a;Регистратор: RegistratorLogin / Registrator123!&#x0a;Врач: DoctorLogin / Doctor123!&#x0a;Медсестра: NurseLogin / Nurse123!&#x0a;Администратор: AdminLogin / Admin123!" 
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>